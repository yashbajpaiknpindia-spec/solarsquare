# ─────────────────────────────────────────────────────────────────────────────
# .env.example  —  Copy to .env for local development
# Never commit .env to version control!
# ─────────────────────────────────────────────────────────────────────────────

# ── Node environment ──────────────────────────────────────────────────────────
NODE_ENV=development

# ── PostgreSQL connection string ──────────────────────────────────────────────
# Local: install PostgreSQL and create a database
#   createdb solgrid
# Then set:
DATABASE_URL=postgresql://postgres:password@localhost:5432/solgrid

# ── Admin dashboard token ─────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
ADMIN_TOKEN=change-me-to-a-strong-secret

# ── Google Analytics 4 Measurement ID (optional) ─────────────────────────────
# Get from: https://analytics.google.com → Admin → Data Streams → Measurement ID
# Leave blank or remove to disable GA tracking
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Server port (Render injects PORT automatically) ───────────────────────────
PORT=3000
